import { VerticalBox } from "std-widgets.slint";

export component GlassPanel {
    // ---- 可定制的外观属性 ----
    in-out property <color> background;
    in-out property <color> bg: #7190aa92;
    in-out property <color> border-color: #87a4bed1;
    in-out property <length> border-radius: 4px;
    in-out property <length> border-width: 2px;
    in-out property <length> radius: 8px;
    in-out property <length> glass-width: 5px;
    in-out property <bool> has-shadow: true;

    // 外层容器（负责尺寸和形状）
    Rectangle {
        border-radius: root.border-radius;
        clip: true;                    // 确保边框不越界

        // 阴影层
        if root.has-shadow : Rectangle {
            border-radius: parent.border-radius;
            background: transparent;
            drop-shadow-blur: 12px;
            drop-shadow-color: black.transparentize(0.5);
            drop-shadow-offset-x: 5px;
            drop-shadow-offset-y: 5px;
            width: 100%;
            height: 100%;
        }
        
        // 半透明毛玻璃主体层
        Rectangle {
            border-radius: parent.border-radius;
            background: root.bg;
            width: 100%;
            height: 100%;
        }

        // ----- 四条固定粗细的渐变边框（色标使用 px） -----
        // 顶边
        top-border := Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: glass-width;
            background: @linear-gradient(180deg, #ffffff.transparentize(40%) 0%, #ffffff.transparentize(80%) 40%, #000000.transparentize(100%) 100%);
        }
        
        // 底边
        bottom-border := Rectangle {
            x: 0;
            y: parent.height - glass-width;
            width: parent.width;
            height: glass-width;
            background: @linear-gradient(0deg, #000000.transparentize(40%) 0%, #000000.transparentize(80%) 60%, #ffffff.transparentize(100%) 100%);
        }
        // 左边
        left-border := Rectangle {
            x: 0;
            y: 0;
            width: glass-width;
            height: parent.height;
            background: @linear-gradient(90deg, #ffffff.transparentize(40%) 0%, #ffffff.transparentize(80%) 40%, #000000.transparentize(100%) 100%);
        }
        // 右边
        right-border := Rectangle {
            x: parent.width - glass-width;
            y: 0;
            width: glass-width;
            height: parent.height;
            background: @linear-gradient(270deg, #000000.transparentize(40%) 0%, #000000.transparentize(80%) 60%, #ffffff.transparentize(100%) 100%);
        }

        // 内容区域（最上层）
        Rectangle {
            @children
        }
    }
}