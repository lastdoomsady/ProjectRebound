<Window x:Class="ProjectRebound.Browser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProjectRebound Browser"
        Height="720"
        Width="1120"
        MinHeight="620"
        MinWidth="960"
        Loaded="Window_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Backend" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0,12,8" Text="{Binding BackendUrl, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Display name" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="3" Margin="8,0,12,8" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="0" Grid.Column="4" Text="Region" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="5" Margin="8,0,0,8" Text="{Binding Region, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Game directory" VerticalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,12,0" Text="{Binding GameDirectory, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Row="1" Grid.Column="2" Margin="0,0,12,0" Content="Browse" Command="{Binding BrowseGameDirectoryCommand}" />
            <Button Grid.Row="1" Grid.Column="3" Margin="0,0,12,0" Content="Save / Login" Command="{Binding SaveCommand}" />
            <TextBlock Grid.Row="1" Grid.Column="4" Text="Version" VerticalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="5" Margin="8,0,0,0" Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Room name" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Margin="8,0,12,0" Text="{Binding RoomName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Column="2" Text="Map" VerticalAlignment="Center" />
            <TextBox Grid.Column="3" Margin="8,0,12,0" Text="{Binding Map, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Column="4" Text="Mode" VerticalAlignment="Center" />
            <TextBox Grid.Column="5" Margin="8,0,12,0" Text="{Binding Mode, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Column="6" Text="Port" VerticalAlignment="Center" />
            <TextBox Grid.Column="7" Margin="8,0,12,0" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Max" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Width="48" Margin="0,0,12,0" Text="{Binding MaxPlayers, UpdateSourceTrigger=PropertyChanged}" />
                <Button Width="80" Margin="0,0,8,0" Content="Refresh" Command="{Binding RefreshCommand}" />
                <Button Width="96" Margin="0,0,8,0" Content="Create" Command="{Binding CreateRoomCommand}" />
                <Button Width="96" Margin="0,0,8,0" Content="Join" Command="{Binding JoinRoomCommand}" />
                <Button Width="116" Content="Quick Match" Command="{Binding QuickMatchCommand}" />
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Rooms}"
                  SelectedItem="{Binding SelectedRoom}"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                <DataGridTextColumn Header="Region" Binding="{Binding Region}" Width="90" />
                <DataGridTextColumn Header="Map" Binding="{Binding Map}" Width="130" />
                <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="150" />
                <DataGridTextColumn Header="Players" Binding="{Binding PlayerCount}" Width="80" />
                <DataGridTextColumn Header="Max" Binding="{Binding MaxPlayers}" Width="60" />
                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="110" />
                <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="150" />
                <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeenAt}" Width="180" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Margin="0,12,0,0" Padding="10" BorderBrush="#CCCCCC" BorderThickness="1">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
